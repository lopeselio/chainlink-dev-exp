# Copy to `.env.local`. All values are optional — sensible defaults are baked in.

# Deployed Snapshot contract to read from (defaults to the live Sepolia deployment).
NEXT_PUBLIC_SNAPSHOT_ADDRESS=0x8ab8054b8b94A8a42719A1D62e08107115660B6A

# Server-side Sepolia RPC used by the API route (defaults to a public endpoint).
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
